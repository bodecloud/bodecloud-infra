{
  "name": "warp-gateway-k8s",
  "version": "1.0.0",
  "description": "CDK8s configuration for warp-gateway",
  "main": "warp-gateway.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "synth": "cdk8s synth",
