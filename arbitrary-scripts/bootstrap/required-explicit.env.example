# ============================================================================
# Zero-SPOF — REQUIRED EXPLICIT CONFIGURATION
# ============================================================================
# Copy to one of:
#   /etc/required-explicit.env          (recommended on VPS)
#   ./required-explicit.env             (repo-local / dev)
#   $REQUIRED_EXPLICIT_FILE             (custom path)
#
# Everything NOT listed here is auto-generated by generate-implicit-env.sh
# (secrets, paths, peer lists, Constellation config, placement dirs, etc.).
#
# Priority: shell env > required-explicit file > bootstrap-config.env > defaults
# ============================================================================

# --- Identity (required) ----------------------------------------------------
# Public DNS zone (e.g. bolabaden.org)
DOMAIN=

# This node's Tailscale/Headscale hostname (e.g. micklethefickle, ci-node2)
TS_HOSTNAME=

# Optional alias used by dont-run-directly.sh when TS_HOSTNAME is unset
#BOOTSTRAP_HOSTNAME=

# --- Cloudflare (required for ACME + node-direct DDNS) ----------------------
# API token with Zone:DNS:Edit (Edit zone DNS template). Prefer token over key.
CLOUDFLARE_API_TOKEN=

# Legacy global API key (optional if token is set)
#CLOUDFLARE_API_KEY=
#CLOUDFLARE_EMAIL=

# Zone ID (optional — auto-discovered from DOMAIN when token is valid)
#CLOUDFLARE_ZONE_ID=

# --- Tailscale / Headscale (required when ENABLE_TAILSCALE=true) ------------
TAILSCALE_AUTH_KEY=

# Defaults to https://headscale.${DOMAIN} when unset
#TAILSCALE_LOGIN_SERVER=

# --- ACME (optional — sensible default) -------------------------------------
#ACME_RESOLVER_EMAIL=admin@${DOMAIN}

# --- Failover cluster (optional — auto-discovered) --------------------------
# Primary placement authority node (defaults to lexicographically first peer)
#FAILOVER_MAIN_HOST=

# Comma-separated peer TS hostnames (defaults: all other nodes on tailnet)
#FAILOVER_PEER_HOSTS=

# --- Constellation (optional) -----------------------------------------------
#ENABLE_CONSTELLATION=true
#CONSTELLATION_CONFIG=/opt/constellation/config.yaml
#CONSTELLATION_JOIN_ADDRS=   # comma-separated host:7946 for multi-node bootstrap

# --- Stack toggles (optional) -----------------------------------------------
#ENABLE_ZERO_SPOF_STACK=true
#ENABLE_NOMAD=false
#ENABLE_CONSUL=false
#ZERO_SPOF_REPO_ROOT=/opt/my-media-stack
