# Failover CI test environment (copy to test.env and customize)
DOMAIN=ci.bolabaden.test
MAIN_HOST=ci-node1
VM_CPUS=2
VM_MEM=4096
VM_DISK=40G
MULTIPASS_IMAGE=22.04

# Dual DNS: Tailscale MagicDNS first, then CoreDNS mesh, then Google
HEADSCALE_MAGICDNS=100.100.100.100
GOOGLE_DNS_1=8.8.8.8
GOOGLE_DNS_2=8.8.4.4

# Compose (no blanket --build; compose-up builds failover-agent + ci-probe explicitly)
COMPOSE_UP_FLAGS="-d --remove-orphans --pull=always"
FAILOVER_ENABLED=true
FAILOVER_REPLICA_ENSURE=false
FAILOVER_REMOTE_DOCKER_PORT=2375
# Auto on DinD; set 0 to force full stack on Multipass/QEMU
# FAILOVER_CI_MINIMAL=1

# Disable Cloudflare mutators in CI mesh; Module 5 proved via dry-run
CLOUDFLARE_DDNS_ENABLED=false
DISABLE_CLOUDFLARE_DDNS=true
OSVC_INGRESS_SYNC_DISABLE=1

# Paths inside each VM
VM_REPO_PATH=/opt/my-media-stack
