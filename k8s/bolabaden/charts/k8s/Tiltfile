# --- Configuration ---
# Set namespace if desired, e.g., create_namespace('media-stack')
NAMESPACE = 'default' # Change if deploying to a specific namespace

# --- Load Manifests ---

# Load secrets, pvcs, configmaps first
k8s_yaml('k8s/01-secrets.yaml')
k8s_yaml('k8s/02-pvcs.yaml')
k8s_yaml('k8s/03-configmaps.yaml')

# Load Traefik (ensure CRDs are applied first if not bundled)
# Assuming Traefik CRDs are already installed or will be by Traefik Helm/Manifest
k8s_yaml('k8s/services/traefik/')

# Load Core Services (Databases, Monitoring etc.)
k8s_yaml('k8s/services/cadvisor/')
k8s_yaml('k8s/services/crowdsec/')
k8s_yaml('k8s/services/keycloak-postgres/')
k8s_yaml('k8s/services/midarr-postgres/')
# k8s_yaml('k8s/services/cloud-postgres/') # Only if using in-cluster DB for Nextcloud
k8s_yaml('k8s/services/prometheus/')
k8s_yaml('k8s/services/redis/')
k8s_yaml('k8s/services/gotify/')

# Load Gluetun Services (Needed before dependent apps)
k8s_yaml('k8s/services/gluetun-airvpn/')
k8s_yaml('k8s/services/gluetun-premiumize/')

# Load Media Management Apps (*arrs, Bazarr, etc.)
k8s_yaml('k8s/services/autobrr/') # Runs behind gluetun-airvpn
k8s_yaml('k8s/services/bazarr/')
k8s_yaml('k8s/services/lidarr/')
k8s_yaml('k8s/services/midarr/')
k8s_yaml('k8s/services/prowlarr/') # Runs behind gluetun-airvpn
k8s_yaml('k8s/services/radarr/')
k8s_yaml('k8s/services/readarr/')
k8s_yaml('k8s/services/recyclarr/')
k8s_yaml('k8s/services/sonarr/')
k8s_yaml('k8s/services/whisparr/')

# Load Download Clients (Run behind gluetun-airvpn)
k8s_yaml('k8s/services/deluge/')
k8s_yaml('k8s/services/jackett/')
k8s_yaml('k8s/services/qbittorrent/')
# k8s_yaml('k8s/services/sabnzbd/') # Add if Sabnzbd manifests are created

