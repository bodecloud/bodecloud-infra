http:
  routers:
    stremio-streaming-server-endpoints:
      rule: "Host(`stremio.bolabaden.org`) && PathRegexp(`^/(hlsv2|casting|local-addon|proxy|rar|zip|settings|create|removeAll|samples|probe|subtitlesTracks|opensubHash|subtitles|network-info|device-info|get-https|hwaccel-profiler|status|exec|stream)`)"
      service: stremio
      entryPoints: ["websecure"]
      middlewares: 
        - headers-add-cors-for-stremio
      tls: {}
    stremio-addon-management:
      rule: "Host(`stremio.bolabaden.org`) && PathRegexp(`^/([^/]+)/(stats\\.json|create|remove|destroy)`)"
      service: stremio
      middlewares: 
        - headers-add-cors-for-stremio
      tls: {}
    stremio-addon-content:
      rule: "Host(`stremio.bolabaden.org`) && PathRegexp(`^/([^/]+)/([^/]+)/(stats\\.json|hls\\.m3u8|master\\.m3u8|stream\\.m3u8|dlna|thumb\\.jpg)`)"
      service: stremio
      middlewares: 
        - headers-add-cors-for-stremio
      tls: {}
    stremio-streaming-playlists:
      rule: "Host(`stremio.bolabaden.org`) && PathRegexp(`^/([^/]+)/([^/]+)/(stream-q-[^/]+\\.m3u8|stream-[^/]+\\.m3u8|subs-[^/]+\\.m3u8)`)"
      service: stremio
      middlewares: 
        - headers-add-cors-for-stremio
      tls: {}
    stremio-streaming-segments:
      rule: "Host(`stremio.bolabaden.org`) && PathRegexp(`^/([^/]+)/([^/]+)/(stream-q-[^/]+|stream-[^/]+)/[^/]+\\.(ts|mp4)`)"
      service: stremio
      middlewares: 
        - headers-add-cors-for-stremio
      tls: {}
    stremio-youtube:
      rule: "Host(`stremio.bolabaden.org`) && PathRegexp(`^/yt/([^/]+)(\\.(json|js))?$`)"
      service: stremio
      middlewares: 
        - headers-add-cors-for-stremio
      tls: {}
    stremio-root-endpoints:
      rule: "Host(`stremio.bolabaden.org`) && PathRegexp(`^/(thumb\\.jpg|stats\\.json)$`)"
      service: stremio
      middlewares: 
        - headers-add-cors-for-stremio
      tls: {}