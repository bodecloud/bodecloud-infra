# Domain settings
DOMAIN=example.com
KEYCLOAK_HOSTNAME=auth.example.com

# Keycloak admin credentials
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-please

# Database settings
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloak-password

# Google SSO settings
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook SSO settings
FACEBOOK_CLIENT_ID=your-facebook-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-client-secret

# Forward auth settings
OIDC_CLIENT_ID=media-stack-client
OIDC_CLIENT_SECRET=client-secret-change-me
FORWARD_AUTH_SECRET=random-secret-change-me
AUTH_HOST=auth.traefik.example.com
COOKIE_DOMAIN=.example.com

# SMTP settings for email notifications
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=no-reply@example.com
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SSL=false
SMTP_STARTTLS=false
SMTP_AUTH=false

# Client settings
CLIENT_SECRET=change-me-please
TRAEFIK_AUTH_SECRET=change-me-please-traefik-auth

# CORS settings
MEDIA_STACK_REDIRECT_URIS=https://*.example.com/*
MEDIA_STACK_WEB_ORIGINS=https://*.example.com 