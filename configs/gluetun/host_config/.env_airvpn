# HTTP Control Panel section references:
# https://github.com/qdm12/gluetun-wiki/blob/main/setup/options/control-server.md
# https://github.com/qdm12/gluetun-wiki/blob/main/setup/advanced/control-server.md
# Listening address for the HTTP control server
HTTP_CONTROL_SERVER_ADDRESS=:8000
# Path to a TOML file containing authentication configuration. There is no default.
HTTP_CONTROL_SERVER_AUTH_CONFIG_FILEPATH=
# Enable logging of HTTP requests
HTTP_CONTROL_SERVER_LOG=on

# DNS reference: https://github.com/qdm12/gluetun-wiki/blob/main/setup/options/dns.md
# Uses ads hostnames and IP addresses block lists for Unbound: https://github.com/qdm12/files
BLOCK_ADS=on
# Uses malicious hostnames and IP addresses block lists for Unbound: https://github.com/qdm12/files
BLOCK_MALICIOUS=on
# Uses surveillance hostnames and IP addresses block lists for Unbound: https://github.com/qdm12/files
BLOCK_SURVEILLANCE=on
# IP address to use as DNS resolver. It defaults to localhost to use the DNS over TLS Unbound server. Tip: use 127.0.0.11 to use the Docker DNS server.
DNS_ADDRESS=127.0.0.1
# Keep /etc/resolv.conf untouched. ⚠️ this will likely leak DNS traffic outside the VPN through your default container DNS. This imples DOT=off and ignores DNS_ADDRESS
DNS_KEEP_NAMESERVER=off
# Period to update block lists and cryptographic files and restart Unbound. Set to 0 to deactivate updates. This does a burst of DNS over TLS requests, which may be blocked if you set BLOCK_MALICIOUS=on for example. examples: `0`, `30s`, `5m`, `24h`
DNS_UPDATE_PERIOD=24h
# Enable caching of DNS over TLS responses
DOT_CACHING=on
# DNS IPv6 resolution
DOT_IPV6=off
# Comma separated list of CIDRs or single IP addresses Unbound won't resolve to. Note that the setting prevents DNS rebinding
DOT_PRIVATE_ADDRESS=
# DNS over TLS providers to use.
DOT_PROVIDERS=cloudflare
# Activate DNS over TLS with Unbound. If DOT=off, Unbound won't run and therefore no file will be downloaded by the program at all. If DOT=on, after tunneling, it downloads at start (and periodically if DNS_UPDATE_PERIOD is not 0):
DOT=on
# Comma separated list of domain names to leave unblocked with Unbound, e.g. `domain1.com,x.domain2.co.uk`
UNBLOCK=off

# firewall references:
# https://github.com/qdm12/gluetun-wiki/blob/main/setup/options/firewall.md
# https://github.com/qdm12/gluetun-wiki/blob/main/errors/firewall.md
# https://github.com/qdm12/gluetun-wiki/blob/main/errors/routing.md
# Comma separated subnets that Gluetun and the containers sharing its network stack are allowed to access. This involves firewall and routing modifications.
FIREWALL_OUTBOUND_SUBNETS=192.168.0.0/16
# Comma separated list of ports that you've forwarded on airvpn's control panel.
FIREWALL_VPN_INPUT_PORTS=20027,23936,36175,42162,52065
# Internal health check server listening address
HEALTH_SERVER_ADDRESS=127.0.0.1:9999
# Duration to wait after a success check to perform another check
HEALTH_SUCCESS_WAIT_DURATION=5s
# Address to ping on every internal health check
HEALTH_TARGET_ADDRESS=cloudflare.com:443
# Additional duration to add to the wait time for each consecutive failure of the VPN
HEALTH_VPN_DURATION_ADDITION=5s
# Initial duration to wait for the VPN to be ready before restarting it
HEALTH_VPN_DURATION_INITIAL=6s

# HTTP Proxy section references:
# https://github.com/qdm12/gluetun-wiki/blob/main/setup/options/http-proxy.md
# https://github.com/qdm12/gluetun-wiki/blob/main/setup/advanced/http-proxy.md
# Internal listening address for the HTTP proxy
HTTPPROXY_LISTENING_ADDRESS=:8888
# Logs every tunnel requests
HTTPPROXY_LOG=off
# Password to use to connect to the HTTP proxy
HTTPPROXY_PASSWORD=proxypassword
# Stealth mode means HTTP proxy headers are not added to your requests
HTTPPROXY_STEALTH=on
# Username to use to connect to the HTTP proxy
HTTPPROXY_USER=proxyuser
# Enable the internal HTTP proxy
HTTPPROXY=off

# AirVPN provider: https://github.com/qdm12/gluetun-wiki/blob/main/setup/providers/airvpn.md
# OpenVPN section references:
# https://github.com/qdm12/gluetun-wiki/blob/main/setup/options/openvpn.md
# https://github.com/qdm12/gluetun-wiki/blob/main/setup/openvpn-configuration-file.md
# https://github.com/qdm12/gluetun-wiki/blob/main/errors/openvpn.md
# Specify a custom auth algorithm to use
OPENVPN_AUTH=sha256
# Specify a custom cipher to use. It will also set ncp-disable if using AES GCM for PIA
OPENVPN_CIPHERS=aes-256-gcm
# Enable/disable IPv6
OPENVPN_IPV6=off
# Set the MSS fix parameter. Set to 0 to use the defaults.
OPENVPN_MSSFIX=0
# Specify a user to run the OpenVPN subprocess. root is default.
OPENVPN_PROCESS_USER=root
# Network protocol to use, only valid for OpenVPN
OPENVPN_PROTOCOL=tcp
# Run OpenVPN as root
OPENVPN_ROOT=no
# Openvpn verbosity level
OPENVPN_VERBOSITY=1
# Set the OpenVPN version to run
OPENVPN_VERSION=2.6
# OpenVPN certificate content (base64 part only). More info found here: https://github.com/qdm12/gluetun-wiki/blob/main/setup/advanced/openvpn-client-encrypted-key.md
#OPENVPN_CERT=
# Specify a custom OpenVPN configuration file to use for the custom VPN provider.
#OPENVPN_CUSTOM_CONFIG=
# OpenVPN encrypted key (base64 part only). More info found here: https://github.com/qdm12/gluetun-wiki/blob/main/setup/advanced/openvpn-client-encrypted-key.md
#OPENVPN_ENCRYPTED_KEY=
# Specify a generally optional target VPN server IP address to use
#OPENVPN_ENDPOINT_IP=
# Specify a generally optional target VPN server port number to use
#OPENVPN_ENDPOINT_PORT=
# Space delimited openvpn flags to pass to openvpn
#OPENVPN_FLAGS=
# Specify a key passphrase to decrypt an encrypted key
#OPENVPN_KEY_PASSPHRASE=
# OpenVPN key (base64 part only). More info found here: https://github.com/qdm12/gluetun-wiki/blob/main/setup/advanced/openvpn-client-key.md
#OPENVPN_KEY=

# Optional API token for the public IP echo service to increase rate limiting
#PUBLICIP_API_KEY=
# Public IP echo service API to use or an echoip URL in the form `echoip#https://xyz`.
#PUBLICIP_API=ipinfo
# Check for public IP address information on VPN connection
#PUBLICIP_ENABLED=on
# Filepath to store the public IP address assigned. This will be removed in the v4 program, instead you might want to use the control server
#PUBLICIP_FILE=/gluetun/publicip.txt

# List of countries to filter servers by.  # todo: add more, i gave up halfway through there were so many.
SERVER_COUNTRIES=Austria,Belgium,Brazil,Bulgaria,Canada,Czech Republic,Estonia,Germany,Ireland,Japan,Latvia,Netherlands,New Zealand,Norway,Romania,Serbia,Singapore,Spain,Sweden,Switzerland,United Kingdom,United States,China,Isle of Man

# Internal listening address for Shadowsocks
SHADOWSOCKS_ADDRESS=:8388
# AEAD Cipher to use for Shadowsocks. Choose between `chacha20-ietf-poly1305`, `aes-128-gcm`, or `aes-256-gcm`
SHADOWSOCKS_CIPHER=chacha20-ietf-poly1305
# Internal listening address for Shadowsocks
SHADOWSOCKS_LISTENING_ADDRESS=:8388
# Logs every tunnel requests
SHADOWSOCKS_LOG=off
# Password to use to connect to Shadowsocks
SHADOWSOCKS_PASSWORD=password
# Enable the internal Shadowsocks proxy
SHADOWSOCKS=off

# Path to the file that will store the VPN servers data.
STORAGE_FILEPATH=/gluetun/servers/servers.json
# Logs a message indicating if a newer version is available once the VPN is connected
VERSION_INFORMATION=on

# Ratio of servers to be found for the update to succeed, compared to the servers already built in the program
UPDATER_MIN_RATIO=0
# Period to update the VPN servers data in memory and to /gluetun/servers.json. Set to 0 to disable. This does a burst of DNS over TLS requests, which may be blocked if you set BLOCK_MALICIOUS=on for example.
UPDATER_PERIOD=24h
# List of providers to update servers data for, when the updater triggers periodically. If left empty, it defaults to the current VPN provider used at start.
UPDATER_VPN_SERVICE_PROVIDERS=airvpn

# Port Forwarding section references:
# https://github.com/qdm12/gluetun-wiki/blob/main/setup/options/port-forwarding.md
# https://github.com/qdm12/gluetun-wiki/blob/main/setup/advanced/vpn-port-forwarding.md
# VPN provider to use.
VPN_SERVICE_PROVIDER=airvpn
# VPN type to use, only two choices available: `openvpn` and `wireguard`
VPN_TYPE=openvpn
# Port redirection for the VPN server side port forwarded.
#VPN_PORT_FORWARDING_LISTENING_PORTS=8388
# File path to use for writing the forwarded port obtained.
#VPN_PORT_FORWARDING_STATUS_FILE=/tmp/gluetun/forwarded_port
# Enable custom port forwarding code for supported providers
#VPN_PORT_FORWARDING=off