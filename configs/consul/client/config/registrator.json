{
  "service": {
    "name": "{{ .Name }}",
    "tags": ["{{ .Tags }}", "traefik.enable=true", "exposed"],
    "port": "{{ .Port }}",
    "address": "${VPS_PUBLIC_IP}",
    "check": {
      "id": "{{ .Name }}-check",
      "name": "{{ .Name }} service check",
      "tcp": "{{ .Address }}:{{ .Port }}",
      "interval": "10s",
      "timeout": "1s"
    }
  }
} 