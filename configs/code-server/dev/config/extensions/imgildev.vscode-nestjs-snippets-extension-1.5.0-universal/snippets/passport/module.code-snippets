{
  "register PassportModule": {
    "prefix": ["ns_passport_module_register", "PassportModule.register"],
    "scope": "typescript",
    "body": ["PassportModule.register({", "  defaultStrategy: '${1:key}',", "}),"],
    "description": "Registers PassportModule with a default authentication strategy (e.g., 'jwt')."
  },
  "registerAsync PassportModule": {
    "prefix": ["ns_passport_module_register_async", "PassportModule.registerAsync"],
    "scope": "typescript",
    "body": ["PassportModule.registerAsync({", "  inject: [ConfigService],", "  useFactory: (configService: ConfigService) => ({", "    defaultStrategy: configService.get('${1:key}'),", "  }),", "}),"],
    "description": "Registers PassportModule using ConfigService for dynamic configuration. Ensure ConfigModule is imported in the same scope."
  }
}
