
x-common-env: &common-env
  TZ: ${TZ:-America/Chicago}
  PUID: ${PUID:-1001}
  PGID: ${PGID:-989}
  UMASK: ${UMASK:-002}

services:
  consul-client:
    image: hashicorp/consul:latest
    container_name: consul-client
    hostname: ${CONSUL_CLIENT_HOSTNAME:-consul-client-${VPS_NAME:-node1}}
    network_mode: "host"  # Use host network for optimal service discovery
    volumes:
      - ${CONFIG_PATH:-./configs}/consul/client/data:/consul/data
      - ${CONFIG_PATH:-./configs}/consul/client/config:/consul/config
    environment:
      <<: *common-env
      CONSUL_BIND_INTERFACE: ${CONSUL_BIND_INTERFACE:-eth0}
    command: >
      agent -client=0.0.0.0
      -node=${CONSUL_CLIENT_HOSTNAME:-consul-client-${VPS_NAME:-node1}}
      -retry-join=${CONSUL_SERVER_ADDRESS:-consul-server.${DOMAIN}}
      -retry-join-wan=${CONSUL_SERVER_ADDRESS:-consul-server.${DOMAIN}}
      -data-dir=/consul/data
      -config-dir=/consul/config
      -domain=consul
      -enable-script-checks=true
    healthcheck:
      test: ["CMD", "consul", "members"]
      interval: 30s
      timeout: 10s
      retries: 3
    restart: always

  # Configure local Traefik as a properly registered Consul service
  traefik-local-registration:
    image: hashicorp/consul:latest
    container_name: traefik-registration
    hostname: ${VPS_NAME:-node1}-traefik-registration
    restart: always
    depends_on:
      - consul-client
    network_mode: "host"
    volumes:
      - ${CONFIG_PATH:-./configs}/consul/client/services:/consul/services:ro
    command: >
      services register
      /consul/services/traefik-local.json

  # Service discovery sidecar - uses confd to monitor Docker and register services with Consul
  service-discovery:
    image: bitnami/consul:latest
    container_name: service-discovery
    hostname: ${SERVICE_DISCOVERY_HOSTNAME:-service-discovery-${VPS_NAME:-node1}}
    network_mode: "host"
    volumes:
      - ${DOCKER_SOCK:-/var/run/docker.sock}:/var/run/docker.sock:ro
      - ${CONFIG_PATH:-./configs}/consul/client/services:/services
    environment:
      <<: *common-env
      VPS_NAME: ${VPS_NAME:-node1}
      VPS_PUBLIC_IP: ${VPS_PUBLIC_IP:-127.0.0.1}
      VPS_REGION: ${VPS_REGION:-default}
      CONSUL_HTTP_ADDR: http://localhost:8500
    entrypoint: /bin/bash
    command: |
      -c "
      # Wait for Consul to be available
      until consul members > /dev/null 2>&1; do
        echo 'Waiting for Consul...'
        sleep 5
      done
      
      # Register services from /services directory
      for svc in /services/*.json; do
        if [ -f \"$$svc\" ]; then
          echo \"Registering service from $$svc\"
          consul services register \"$$svc\"
        fi
      done
      
      # Watch Docker events and register/deregister services
      /services/docker-service-watch.sh
      "
    depends_on:
      - consul-client
    restart: always