# Failover-agent — Compose-first HA route + replica maintainer
FROM golang:1.24-bookworm AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /failover-agent ./cmd/failover-agent

FROM debian:bookworm-slim
RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates wget \
  && rm -rf /var/lib/apt/lists/*
COPY --from=build /failover-agent /usr/local/bin/failover-agent
EXPOSE 8082
USER nobody
ENTRYPOINT ["/usr/local/bin/failover-agent"]
